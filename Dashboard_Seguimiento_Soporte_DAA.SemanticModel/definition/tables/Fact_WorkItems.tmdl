	partition Fact_WorkItems = m
		mode: import
		source =
				let
				    mode = Text.Upper(Text.Trim(Text.From(pSourceMode))),
				    Fact_WorkItems =
				        if mode = "CSV" then transform_workitems_csv
				        else if mode = "WIQL" then transform_workitems_wiql
				        else if mode = "ODATA" then transform_workitems_odata
				        else error "pSourceMode inválido. Use CSV, WIQL u OData."
				in
				    Fact_WorkItems

	changedProperty = IsHidden

	annotation PBI_NavigationStepName = Navegación

	annotation PBI_ResultType = Table

