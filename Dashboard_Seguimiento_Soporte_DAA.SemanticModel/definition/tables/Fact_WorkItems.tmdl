table Fact_WorkItems
	lineageTag: 8f670d41-9369-470a-bd08-e103a86a5647

	measure 'Total Work Items' = COUNTROWS(Fact_WorkItems)
		formatString: 0
		lineageTag: 630536c7-c832-49b8-b190-69e234466b29

	measure 'Total Tracks' =
			
			CALCULATE(
			    DISTINCTCOUNT(Fact_WorkItems[TrackCode]),
			    Fact_WorkItems[TrackCode] <> "T00"
			)
		formatString: 0
		lineageTag: 722414a3-dee3-4270-b2ef-1871b0522694

	measure 'Total User Stories' =
			
			CALCULATE(
			    COUNTROWS(Fact_WorkItems),
			    Fact_WorkItems[IsUserStory] = TRUE()
			)
		formatString: 0
		lineageTag: 38e2563d-779a-4a73-b382-3ea967cf57c9

	measure 'Total Tasks' =
			
			CALCULATE(
			    COUNTROWS(Fact_WorkItems),
			    Fact_WorkItems[IsTask] = TRUE()
			)
		formatString: 0
		lineageTag: 8fbe4a68-ecf8-49b7-8c01-0b076557bf99

	measure 'Tasks Sin Responsable' =
			
			CALCULATE(
			    COUNTROWS(Fact_WorkItems),
			    Fact_WorkItems[IsTask] = TRUE(),
			    Fact_WorkItems[HasOwner] = FALSE()
			)
		formatString: 0
		lineageTag: ba4a9962-9b81-42f0-bbed-04e6191c6500


	measure 'Avance Global %' =
			
			DIVIDE(
			    CALCULATE(COUNTROWS(Fact_WorkItems), Fact_WorkItems[StateNormalized] = "Done"),
			    [Total Tasks],
			    0
			)
		formatString: 0.00%

	measure 'Avance Ponderado %' =
			
			DIVIDE(
			    SUMX(
			        FILTER(Fact_WorkItems, Fact_WorkItems[IsTask] = TRUE()),
			        Fact_WorkItems[ProgressWeight] * IF(Fact_WorkItems[StateNormalized] = "Done", 1, 0)
			    ),
			    SUMX(FILTER(Fact_WorkItems, Fact_WorkItems[IsTask] = TRUE()), Fact_WorkItems[ProgressWeight]),
			    0
			)
		formatString: 0.00%

	measure 'Work Items con jerarquía incompleta' =
			
			CALCULATE(
			    COUNTROWS(Fact_WorkItems),
			    Fact_WorkItems[HierarchyStatus] <> "OK"
			)
		formatString: 0

	measure 'Tracks sin clasificar' =
			
			CALCULATE(
			    DISTINCTCOUNT(Fact_WorkItems[TrackCode]),
			    Fact_WorkItems[TrackCode] = "T00"
			        || ISBLANK(Fact_WorkItems[TrackCode])
			)
		formatString: 0

	measure 'Tasks sin User Story' =
			
			CALCULATE(
			    COUNTROWS(Fact_WorkItems),
			    Fact_WorkItems[IsTask] = TRUE(),
			    ISBLANK(Fact_WorkItems[UserStoryWorkItemId])
			)
		formatString: 0

	measure 'User Stories sin Feature' =
			
			CALCULATE(
			    COUNTROWS(Fact_WorkItems),
			    Fact_WorkItems[IsUserStory] = TRUE(),
			    ISBLANK(Fact_WorkItems[FeatureWorkItemId])
			)
		formatString: 0

