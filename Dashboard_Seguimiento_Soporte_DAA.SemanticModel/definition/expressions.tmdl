expression transform_workitems_csv =
		let
		    Source = Csv.Document(File.Contents(pCsvPath), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
		    H = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
		    C = Table.TransformColumnNames(H, each Text.Trim(_)),
		    T0 = Table.TransformColumnTypes(C,{{"ID", Int64.Type},{"Work Item Type", type text},{"Title 1", type text},{"Title 2", type text},{"Title 3", type text},{"Parent", Int64.Type},{"State", type text},{"Assigned To", type text},{"Tags", type text},{"Created Date", type datetime},{"Changed Date", type datetime},{"Closed Date", type datetime},{"Faena", type text},{"Fecha Inicio", type date},{"Fecha Fin", type date},{"Priority", Int64.Type},{"Iteration Path", type text},{"Board Column", type text},{"Board Column Done", type logical}}),
		    I = Table.AddIndexColumn(T0, "SortOrder", 1, 1, Int64.Type),
		    A1 = Table.AddColumn(I,"WorkItemId", each [ID], Int64.Type),
		    A2 = Table.AddColumn(A1,"WorkItemType", each Text.Proper(Text.Trim(Text.From([Work Item Type]))), type text),
		    A3 = Table.AddColumn(A2,"IsFeature", each [WorkItemType]="Feature", type logical),
		    A4 = Table.AddColumn(A3,"IsUserStory", each [WorkItemType]="User Story", type logical),
		    A5 = Table.AddColumn(A4,"IsTask", each [WorkItemType]="Task", type logical),
		    A6 = Table.AddColumn(A5,"ParentWorkItemId", each try Number.From([Parent]) otherwise null, Int64.Type),
		    A7 = Table.AddColumn(A6,"FeatureWorkItemId", each if [IsFeature] then [WorkItemId] else if [IsUserStory] then [ParentWorkItemId] else null, Int64.Type),
		    A8 = Table.AddColumn(A7,"UserStoryWorkItemId", each if [IsUserStory] then [WorkItemId] else if [IsTask] then [ParentWorkItemId] else null, Int64.Type),
		    FeatMap = Table.RenameColumns(Table.SelectColumns(Table.SelectRows(A8, each [IsFeature]=true),{"WorkItemId","Title 1"}),{{"WorkItemId","FeatureWorkItemId"},{"Title 1","FeatureTitle"}}),
		    J1 = Table.NestedJoin(A8,{"FeatureWorkItemId"},FeatMap,{"FeatureWorkItemId"},"F",JoinKind.LeftOuter),
		    E1 = Table.ExpandTableColumn(J1,"F",{"FeatureTitle"},{"FeatureTitle"}),
		    UsMap = Table.RenameColumns(Table.SelectColumns(Table.SelectRows(A8, each [IsUserStory]=true),{"WorkItemId","Title 2","Faena","Fecha Inicio","Fecha Fin","Tags","Assigned To"}),{{"WorkItemId","UserStoryWorkItemId"},{"Title 2","UserStoryTitle"},{"Faena","FaenaUS"},{"Fecha Inicio","FechaInicioUS"},{"Fecha Fin","FechaFinUS"},{"Tags","TagsUS"},{"Assigned To","AssignedToUS"}}),
		    J2 = Table.NestedJoin(E1,{"UserStoryWorkItemId"},UsMap,{"UserStoryWorkItemId"},"US",JoinKind.LeftOuter),
		    E2 = Table.ExpandTableColumn(J2,"US",{"UserStoryTitle","FaenaUS","FechaInicioUS","FechaFinUS","TagsUS","AssignedToUS"},{"UserStoryTitle","FaenaUS","FechaInicioUS","FechaFinUS","TagsUS","AssignedToUS"}),
		    A9 = Table.AddColumn(E2,"TaskTitle", each if [IsTask] then [Title 3] else null, type text),
		    A10 = Table.AddColumn(A9,"DisplayTitle", each if [IsFeature] then [Title 1] else if [IsUserStory] then [Title 2] else [Title 3], type text),
		    A11 = Table.AddColumn(A10,"TrackRec", each FunctionsAzureDevOps[FnTrackFromText]([FeatureTitle])),
		    A12 = Table.ExpandRecordColumn(A11,"TrackRec",{"TrackCode","TrackName"},{"TrackCode","TrackName"}),
		    A13 = Table.AddColumn(A12,"FaenaOriginal", each [Faena], type text),
		    A14 = Table.AddColumn(A13,"FaenaSeguimiento", each if [IsTask] then if [Faena]<>null and Text.Trim([Faena])<>"" then [Faena] else [FaenaUS] else if [IsUserStory] then [Faena] else null, type text),
		    A15 = Table.AddColumn(A14,"FechaInicioOriginal", each [#"Fecha Inicio"], type date),
		    A16 = Table.AddColumn(A15,"FechaFinOriginal", each [#"Fecha Fin"], type date),
		    A17 = Table.AddColumn(A16,"FechaInicioSeguimiento", each if [IsTask] and [#"Fecha Inicio"] = null then [FechaInicioUS] else [#"Fecha Inicio"], type date),
		    A18 = Table.AddColumn(A17,"FechaFinSeguimiento", each if [IsTask] and [#"Fecha Fin"] = null then [FechaFinUS] else [#"Fecha Fin"], type date),
		    A19 = Table.AddColumn(A18,"TagsOriginal", each [Tags], type text),
		    A20 = Table.AddColumn(A19,"TagsSeguimiento", each if [IsTask] and ([Tags]=null or Text.Trim([Tags])="") then [TagsUS] else [Tags], type text),
		    A21 = Table.AddColumn(A20,"AssignedToRaw", each if [IsTask] and ([#"Assigned To"] = null or Text.Trim([#"Assigned To"])="") then [AssignedToUS] else [#"Assigned To"], type text),
		    A22 = Table.AddColumn(A21,"AssignedRec", each FunctionsAzureDevOps[FnParseAssignedTo]([AssignedToRaw])),
		    A23 = Table.ExpandRecordColumn(A22,"AssignedRec",{"AssignedToName","AssignedToEmail"},{"AssignedToName","AssignedToEmail"}),
		    A24 = Table.AddColumn(A23,"ResponsableSeguimiento", each [AssignedToName], type text),
		    A25 = Table.AddColumn(A24,"TipoTrabajo", each let tg=Text.Upper(Text.From([TagsSeguimiento])) in if Text.Contains(tg,"AUTOMATIZACIONES") then "Automatización" else if Text.Contains(tg,"FOLLOW") then "Follow" else if Text.Contains(tg,"TOMA DE CONTROL") then "Toma de Control" else if Text.Contains(tg,"ACTIVIDAD DE SOPORTE") then "Actividad de Soporte" else if Text.Contains(tg,"MONITOREO") then "Monitoreo" else if Text.Contains(tg,"PERMISO") then "Permiso" else if Text.Contains(tg,"DOCUMENTACION") then "Documentación" else if Text.Contains(tg,"TRASPASO EQUIPO") then "Traspaso Equipo" else if Text.Contains(tg,"TRASPASO AMG") then "Traspaso AMG" else "Sin clasificar", type text),
		    A26 = Table.AddColumn(A25,"EtapaSeguimiento", each let tg=Text.Upper(Text.From([TagsSeguimiento])) in if Text.Contains(tg,"MONITOREO") then "MONITOREO" else if Text.Contains(tg,"TOMA DE CONTROL") then "TOMA DE CONTROL" else if Text.Contains(tg,"TRASPASO EQUIPO") then "TRASPASO EQUIPO" else if Text.Contains(tg,"TRASPASO AMG") then "TRASPASO AMG" else if Text.Contains(tg,"FOLLOW") then "FOLLOW" else if Text.Contains(tg,"ACTIVIDAD DE SOPORTE") then "ACTIVIDAD DE SOPORTE" else if Text.Contains(tg,"PERMISO") then "PERMISO" else if Text.Contains(tg,"DOCUMENTACION") then "DOCUMENTACION" else if Text.Contains(tg,"AUTOMATIZACIONES") then "AUTOMATIZACIONES" else "SIN ETAPA", type text),
    A26b = Table.AddColumn(A26,"WeeklySeguimiento", each let tg=Text.Upper(Text.From([TagsSeguimiento])) in if Text.Contains(tg,"AUTOMATIZACIONES") then "AUTOMATIZACIONES" else if Text.Contains(tg,"MLP") then "MLP" else if Text.Contains(tg,"CEN") then "CEN" else if Text.Contains(tg,"ANT") then "ANT" else if Text.Contains(tg,"CMZ") then "CMZ" else if Text.Contains(tg,"AMSA") then "AMSA" else "Sin weekly", type text),
    A26c = Table.AddColumn(A26b,"MostrarEnWeekly", each let tg=Text.Upper(Text.From([TagsSeguimiento])) in if Text.Contains(tg,"INCIDENCIA") then "No" else if [WeeklySeguimiento] = "Sin weekly" then "No" else "Sí", type text),
    A26d = Table.AddColumn(A26c,"MotivoWeekly", each let tg=Text.Upper(Text.From([TagsSeguimiento])) in if Text.Contains(tg,"INCIDENCIA") then "Incidencia excluida de vista weekly" else if [WeeklySeguimiento] = "Sin weekly" then "Sin tag de weekly" else "Incluido en weekly", type text),
    A26e = Table.AddColumn(A26d,"StateNormalized", each if List.Contains({"Closed","Done"},[State]) then "Cerrado" else if List.Contains({"Active","In Progress","Resolved"},[State]) then "En curso" else "Pendiente", type text),
		    A27 = Table.AddColumn(A26e,"HasOwner", each [AssignedToName]<>null and Text.Trim([AssignedToName])<>"", type logical),
		    A28 = Table.AddColumn(A27,"ProgressWeight", each if [StateNormalized]="Cerrado" then 1 else if [StateNormalized]="En curso" then 0.5 else 0, type number),
		    A29 = Table.AddColumn(A28,"SourceMode", each "CSV", type text),
		    A30 = Table.AddColumn(A29,"AreaPath", each null, type text),
		    A31 = Table.AddColumn(A30,"CreatedDate", each [#"Created Date"], type datetime),
		    A32 = Table.AddColumn(A31,"ChangedDate", each [#"Changed Date"], type datetime),
		    A33 = Table.AddColumn(A32,"ClosedDate", each [#"Closed Date"], type datetime),
		    A34 = Table.AddColumn(A33,"IterationPath", each [#"Iteration Path"], type text),
		    A35 = Table.AddColumn(A34,"BoardColumn", each [#"Board Column"], type text),
		    A36 = Table.AddColumn(A35,"BoardColumnDone", each [#"Board Column Done"], type logical),
		    A37 = Table.AddColumn(A36,"HierarchyStatus", each if [IsTask] and [UserStoryWorkItemId]=null then "Task sin User Story" else if [IsUserStory] and [FeatureWorkItemId]=null then "User Story sin Feature" else if [TrackCode]=null then "Track no detectado" else "OK", type text),
		    A38 = Table.ReplaceValue(A37,null,"T00",Replacer.ReplaceValue,{"TrackCode"}),
		    A39 = Table.ReplaceValue(A38,null,"Track sin clasificar",Replacer.ReplaceValue,{"TrackName"}),
		    S = Table.SelectColumns(A39,{"WorkItemId","WorkItemType","DisplayTitle","ParentWorkItemId","FeatureWorkItemId","FeatureTitle","UserStoryWorkItemId","UserStoryTitle","TaskTitle","TrackCode","TrackName","FaenaOriginal","FaenaSeguimiento","FechaInicioOriginal","FechaFinOriginal","FechaInicioSeguimiento","FechaFinSeguimiento","TagsOriginal","TagsSeguimiento","WeeklySeguimiento","MostrarEnWeekly","MotivoWeekly","TipoTrabajo","EtapaSeguimiento","AssignedToName","ResponsableSeguimiento","State","StateNormalized","Priority","IterationPath","BoardColumn","BoardColumnDone","CreatedDate","ChangedDate","ClosedDate","HierarchyStatus","AssignedToEmail","HasOwner","IsFeature","IsUserStory","IsTask","SortOrder","ProgressWeight","SourceMode","AreaPath"})
		in
		    S
	lineageTag: df43366b-8f44-437d-b064-efb539a090f6

