{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.9.0/schema.json",
  "name": "so_bar_owner",
  "position": {
    "x": 640,
    "y": 20,
    "z": 2,
    "height": 260,
    "width": 610,
    "tabOrder": 2
  },
  "visual": {
    "visualType": "clusteredColumnChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Fact_WorkItems"
                    }
                  },
                  "Property": "AssignedToName"
                }
              },
              "queryRef": "Fact_WorkItems.AssignedToName",
              "nativeQueryRef": "AssignedToName",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Fact_WorkItems"
                    }
                  },
                  "Property": "Total Tasks"
                }
              },
              "queryRef": "Fact_WorkItems.Total Tasks",
              "nativeQueryRef": "Total Tasks"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}